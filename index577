<script>
function openMenu()  { document.getElementById('mobileMenu').classList.add('open'); }
function closeMenu() { document.getElementById('mobileMenu').classList.remove('open'); }

// RƏNG MƏLUMATLARI
const COLORS = [
  { n:"Qara", bg:"#1c1c1c", img:"30-siyah.webp" },
  { n:"Tünd Göy", bg:"#002a5c", img:"51-lacivert-koyu.webp" },
  { n:"Qırmızı", bg:"#cc0000", img:"8-kirmizi.webp" },
  { n:"Yaşıl", bg:"#1a6e00", img:"38-yesil.webp" },
  { n:"Sarı", bg:"#f0d000", img:"11-sari.webp" },
  { n:"Tünd Mavi", bg:"#00008b", img:"" },
  { n:"Qəhvəyi", bg:"#5c3317", img:"" },
  { n:"Bənövşəyi", bg:"#6600cc", img:"" }
  // Digər rəngləri bura eyni formatda əlavə edə bilərsən
];

const SHOW = 5;
const area = document.getElementById('stackArea');
let queue = COLORS.map((_, i) => i);
let busy = false;

function buildStack() {
  area.innerHTML = '';
  const visible = Math.min(SHOW, queue.length);
  for (let i = visible - 1; i >= 0; i--) {
    const col = COLORS[queue[i]];
    const card = document.createElement('div');
    card.className = 'scard';
    card.dataset.pos = i;

    // ŞƏKİL MƏNTİQİ: contain istifadə olunur
    const fillStyle = col.img 
      ? `background-image:url('${col.img}');` 
      : `background:${col.bg};`;

    card.innerHTML = `
      <div class="fill" style="${fillStyle}"></div>
      <div class="meta">
        <div class="nm">${col.n}</div>
        <div class="no">№${String(queue[i]+1).padStart(2,'0')} — Viktoria</div>
      </div>`;
    area.appendChild(card);
  }
  updateTexts();
}

function updateTexts() {
  const col = COLORS[queue[0]];
  const info = {
    cnt: (COLORS.length - queue.length + 1) + ' / ' + COLORS.length,
    name: col.n,
    num: '№' + String(queue[0]+1).padStart(2,'0') + ' — Viktoria'
  };
  document.getElementById('desktopCount').textContent = info.cnt;
  document.getElementById('desktopName').textContent = info.name;
  document.getElementById('desktopNum').textContent = info.num;
  document.getElementById('mobileCount').textContent = info.cnt;
  document.getElementById('mobileName').textContent = info.name;
  document.getElementById('mobileNum').textContent = info.num;
}

function goNext() {
  if (busy) return;
  busy = true;
  const top = area.querySelector('.scard[data-pos="0"]');
  if (top) top.classList.add('fly-back');
  setTimeout(() => {
    queue.push(queue.shift());
    buildStack();
    busy = false;
  }, 400);
}

function goPrev() {
  if (busy) return;
  queue.unshift(queue.pop());
  buildStack();
}

document.getElementById('btnNextD').onclick = goNext;
document.getElementById('btnPrevD').onclick = goPrev;
document.getElementById('btnNextM').onclick = goNext;
document.getElementById('btnPrevM').onclick = goPrev;
area.onclick = goNext;

// GRID YARATMAQ
const grid = document.getElementById('colorGrid');
COLORS.forEach((c, i) => {
  const cell = document.createElement('div');
  cell.className = 'color-cell';
  cell.style.backgroundColor = c.bg;
  cell.onclick = () => alert('Rəng: ' + c.n + ' (№' + (i+1) + ')');
  grid.appendChild(cell);
});

buildStack();

// SCROLL ANIMATION
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>

