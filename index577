  .section-sub { font-size: 14px; line-height: 1.7; color: var(--gray); text-align: center; max-width: 520px; margin: 0 auto 40px; }

  /* FEATURE CARDS */
  .cards-stack { display: flex; flex-direction: column; gap: 16px; }
  .feature-card { background: var(--green); border-radius: var(--radius); padding: 24px 20px; position: relative; overflow: hidden; }
  .card-tags { display: flex; justify-content: space-between; margin-bottom: 16px; }
  .card-tag { display: inline-block; border: 1.5px solid var(--black); border-radius: 100px; padding: 5px 12px; font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--black); }
  .card-title { font-family: 'Syne', sans-serif; font-size: clamp(36px, 12vw, 58px); font-weight: 800; letter-spacing: -2px; line-height: 1; margin-bottom: 20px; }
  .card-body { display: flex; gap: 12px; align-items: flex-start; }
