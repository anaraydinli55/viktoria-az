<style>
  :root {
    --green: #3dffa0;
    --green-mid: #a8ffda;
    --green-light: #e8fff5;
    --black: #0a0a0a;
    --white: #ffffff;
    --gray: #888888;
    --gray-light: #f4f4f4;
    --radius: 24px;
  }
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--black); overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 24px;
    background: rgba(61,255,160,0.85);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px;
    letter-spacing: -0.5px; color: var(--black); text-decoration: none;
  }
  .nav-logo svg { width: 32px; height: 32px; }
  .nav-hamburger { display: flex; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
  .nav-hamburger span { display: block; width: 26px; height: 2px; background: var(--black); border-radius: 2px; transition: 0.3s; }

  /* MOBILE MENU */
  .mobile-menu {
    display: none; position: fixed; inset: 0; z-index: 99;
    background: var(--green); flex-direction: column;
    align-items: center; justify-content: center; gap: 36px;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a { font-family: 'Syne', sans-serif; font-size: 32px; font-weight: 800; color: var(--black); text-decoration: none; letter-spacing: -1px; }
  .mobile-menu .close-btn { position: absolute; top: 22px; right: 24px; font-size: 32px; cursor: pointer; color: var(--black); font-family: 'Syne', sans-serif; }

  /* HERO */
  .hero {
    min-height: 100vh;
    background: linear-gradient(180deg, var(--green) 0%, var(--green-light) 100%);
    display: flex; flex-direction: column; overflow: hidden; padding-top: 70px;
  }
  .hero-marquee-wrap { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 40px 0 0; gap: 0; }
  .marquee-row { overflow: hidden; line-height: 1; width: 100%; }
  .marquee-track { display: flex; white-space: nowrap; will-change: transform; width: max-content; }
  .marquee-row:nth-child(1) .marquee-track { animation: mq-left  36s linear infinite; }
  .marquee-row:nth-child(2) .marquee-track { animation: mq-right 42s linear infinite; }
  .marquee-row:nth-child(3) .marquee-track { animation: mq-left  30s linear infinite; }
  .marquee-row:nth-child(4) .marquee-track { animation: mq-right 39s linear infinite; }
  @keyframes mq-left  { 0% { transform: translateX(0); }    100% { transform: translateX(-50%); } }
  @keyframes mq-right { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }
  .marquee-text {
    font-family: 'Syne', sans-serif; font-weight: 800;
    font-size: clamp(72px, 22vw, 130px); letter-spacing: -2px;
    padding: 0 40px; display: inline-block; user-select: none; flex-shrink: 0;
  }
  .marquee-row.outline .marquee-text { color: transparent; -webkit-text-stroke: 2px rgba(255,255,255,0.85); }
  .marquee-row.white   .marquee-text { color: var(--white); }
  .marquee-row.faint   .marquee-text { color: rgba(255,255,255,0.35); }
  .marquee-row.black   .marquee-text { color: var(--black); }
  .hero-bottom { padding: 32px 24px 40px; text-align: center; }
  .hero-tagline { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--black); opacity: 0.7; margin-bottom: 20px; }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--black); color: var(--white);
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px;
    padding: 14px 28px; border-radius: 100px; text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,0.25); }

  /* ══ STACK CAROUSEL ══ */
  .carousel-section { padding: 56px 24px 48px; background: #f9f9f9; border-bottom: 1px solid #eee; }
  .carousel-inner { display: flex; align-items: center; justify-content: center; gap: 56px; }

  .stack-area { position: relative; width: 230px; height: 290px; cursor: pointer; flex-shrink: 0; user-select: none; }

  .scard {
    position: absolute; inset: 0; border-radius: 20px; overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 10px 36px rgba(0,0,0,0.13);
    transition: transform .52s cubic-bezier(.4,0,.2,1), opacity .52s;
    background: #fff; /* Şəkil olmayan hissələr ağ olsun */
    will-change: transform;
  }

  /* GÖRSEL AYARLARI: Tam görünməsi üçün background-size: contain edildi */
  .scard .fill { 
    width: 100%; 
    height: 75%; 
    display: block; 
    background-size: contain; 
    background-position: center; 
    background-repeat: no-repeat;
    background-color: #fff;
  }

  .scard .meta { height: 25%; background: #fff; display: flex; flex-direction: column; justify-content: center; padding: 0 14px; gap: 2px; border-top: 1px solid #f0f0f0; }
  .scard .meta .nm { font-size: 13px; font-weight: 700; color: #111; font-family: 'Syne', sans-serif; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .scard .meta .no { font-size: 11px; color: #aaa; font-family: 'Inter', sans-serif; }

  .scard[data-pos="0"] { transform: translate(  0px,  0px) rotate( 0deg); z-index:5; opacity:1.00; }
  .scard[data-pos="1"] { transform: translate( 10px, -8px) rotate( 4deg); z-index:4; opacity:0.88; }
  .scard[data-pos="2"] { transform: translate( 20px,-16px) rotate( 8deg); z-index:3; opacity:0.76; }
  .scard[data-pos="3"] { transform: translate( 30px,-24px) rotate(12deg); z-index:2; opacity:0.60; }
  .scard[data-pos="4"] { transform: translate( 40px,-32px) rotate(16deg); z-index:1; opacity:0.44; }

  .scard.fly-back {
    transform: translate(-190px, 60px) rotate(-36deg) scale(.74) !important;
    opacity: 0 !important; z-index: 10 !important;
    transition: transform .44s cubic-bezier(.4,0,.2,1), opacity .32s;
  }

  .carousel-info { display: flex; flex-direction: column; gap: 6px; min-width: 160px; }
  .ci-count { font-size: 13px; color: #aaa; font-family: 'Inter', sans-serif; }
  .ci-name  { font-family: 'Syne', sans-serif; font-size: 30px; font-weight: 800; color: var(--black); line-height: 1.1; letter-spacing: -1px; }
  .ci-num   { font-size: 12px; color: #aaa; font-family: 'Inter', sans-serif; font-style: italic; }
  .ci-btns  { display: flex; gap: 10px; margin-top: 16px; }
  .ci-btn {
    width: 44px; height: 44px; border-radius: 50%; border: 1.5px solid #ddd;
    background: #fff; color: var(--black); font-size: 18px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s, border-color .2s; line-height: 1;
  }
  .ci-btn:hover { background: var(--green); border-color: var(--green); }

  .carousel-mobile-info { display: none; flex-direction: column; align-items: center; gap: 6px; margin-top: 28px; text-align: center; }
  .carousel-mobile-btns { display: none; justify-content: center; gap: 12px; margin-top: 16px; }

  @media (max-width: 600px) {
    .carousel-inner { flex-direction: column; gap: 0; }
    .carousel-info  { display: none; }
    .carousel-mobile-info { display: flex; }
    .carousel-mobile-btns { display: flex; }
    /* Mobildə kart sahəsini bir az daha genişləndirdik */
    .stack-area { width: 210px; height: 270px; margin: 0 auto; }
  }

  /* SECTIONS */
  section { padding: 60px 20px; }
